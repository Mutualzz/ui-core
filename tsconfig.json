{
    "compilerOptions": {
        "target": "es2024",
        "module": "ESNext",
        "declaration": false,
        "emitDeclarationOnly": false,
        "outDir": "dist",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "verbatimModuleSyntax": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "strict": true,
        "jsx": "react-jsx",
        "jsxImportSource": "@emotion/react",
        "rootDir": "./src",
        "paths": {
            "@utils": ["./src/utils/index"],
            "@hooks/*": ["./src/hooks/*"],
            "@utils/*": ["./src/utils/*"],
            "@styled": ["./src/utils/styled"],
            "@ui-types": ["./src/types/index.ts"],
            "@ui-types/*": ["./src/types/*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["dist", "dist/**", "**/dist/**"]
}
